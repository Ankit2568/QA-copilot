# --- Required ---
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# --- Gemini tuning (all optional) ---
# Any JSON-mode-capable Gemini model. See https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT_MS=60000
GEMINI_MAX_RETRIES=2

# --- Public site URL (used for OG images, sitemap, robots) ---
# Vercel sets VERCEL_URL automatically; only set this if you have a custom domain.
# NEXT_PUBLIC_SITE_URL=https://qa-copilot.example.com

# Optional version label shown by /api/health.
# NEXT_PUBLIC_APP_VERSION=1.0.0
